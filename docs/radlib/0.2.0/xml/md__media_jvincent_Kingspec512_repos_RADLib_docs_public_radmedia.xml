<codeline><highlight class="normal"></highlight><highlight class="keywordflow">if</highlight><highlight class="normal"><sp/>(!player.<ref refid="classRADMedia_1_1AudioPlayer_1a40697813cfb44160f100e2093105d105" kindref="member">playFile</ref>(</highlight><highlight class="stringliteral">&quot;chime.wav&quot;</highlight><highlight class="normal">,<sp/></highlight><highlight class="stringliteral">&quot;default&quot;</highlight><highlight class="normal">,<sp/>&amp;error))<sp/>{</highlight></codeline>
