<codeline><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal">player.<ref refid="classRADMedia_1_1AudioPlayer_1a4de36336c4f5a42db56dd6de26a8b069" kindref="member">finished</ref>.connect([&amp;loop]()<sp/>{<sp/>loop.<ref refid="classRADCore_1_1EventLoop_1ae8a1e1a8dc12ed6a70792d450feb5632" kindref="member">quit</ref>();<sp/>});</highlight></codeline>
<codeline><highlight class="normal"></highlight></codeline>
